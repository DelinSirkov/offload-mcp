# Base URL of the Offload API. Defaults to production.
OFFLOAD_API_BASE=https://offloads.io

# Optional API key for authenticated actions (post_task / task_status).
# get_quote works without a key. Leave blank to run quote-only.
OFFLOAD_API_KEY=

# Port for the remote HTTP server (npm run start:http). Default 8787.
PORT=8787
