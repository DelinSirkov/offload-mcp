{
  "name": "offload-mcp",
  "version": "0.1.0",
  "description": "Offload MCP server — delegate a real-world task to a vetted human, straight from your AI chat. Get an instant AI quote, post a task, and track it.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "offload-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "manifest.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "offload",
    "task-delegation",
    "virtual-assistant",
    "claude",
    "ai-agent",
    "human-in-the-loop"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
